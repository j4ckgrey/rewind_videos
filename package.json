{
  "name": "@rewind/conduit",
  "version": "1.0.0",
  "description": "The Conduit — yt-dlp online video (trailers, Videos library, YouTube Music) for Rewind, packaged as an operator-installed addon.",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/plugin.ts --bundle --format=esm --platform=node --target=node22 --outfile=dist/index.mjs --tsconfig=tsconfig.json --external:ytdlp-nodejs"
  },
  "dependencies": {
    "ytdlp-nodejs": "^3.4.4"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  }
}
